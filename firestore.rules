// firestore.rules
// Dental Clinic Appointment System — Staff/Admin App
//
// IMPORTANT: Firestore security rules are scoped to the ENTIRE Firebase project,
// not per-app. Since this project's Firestore is shared with the separate,
// already-live patient app, these rules must accommodate BOTH apps' access
// patterns — not just this repo's.
//
// Sections marked with ⚠️ ASSUMPTION need to be confirmed against the patient
// app's actual client-side read/write behavior before this file is deployed.
// Deploying an incorrect assumption here could break the live patient app.

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- Helper functions ----------

    function isSignedIn() {
      return request.auth != null;
    }

    function staffDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isStaffOrAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && staffDoc().data.role in ['staff', 'admin'];
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && staffDoc().data.role == 'admin';
    }

    // ⚠️ ASSUMPTION: patients are NOT expected to have a corresponding doc in
    // `users/{uid}` — that collection is staff/admin only per the spec. This
    // function checks only "is this the appointment's own patient," using the
    // appointment document itself, not a users lookup.
    function isOwningPatient(appointmentData) {
      return isSignedIn()
        && 'userId' in appointmentData
        && appointmentData.userId == request.auth.uid;
    }

    // ---------- users (patient, staff, admin accounts) ----------

    match /users/{uid} {
      allow read: if isStaffOrAdmin() || (isSignedIn() && request.auth.uid == uid);

      // Staff/admin and patient profile edits: allow users to update their own non-role fields.
      allow update: if isAdmin()
        // Staff updating their own non-role fields.
        || (isSignedIn() && request.auth.uid == uid && request.resource.data.role == resource.data.role)
        // Patient marking themselves verified (only allowed field change: isVerified true, updatedAt).
        || (
          isSignedIn()
          && request.auth.uid == uid
          && resource.data.role == 'patient'
          && request.resource.data.role == 'patient'
          && request.resource.data.isVerified == true
          && resource.data.isVerified == false
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isVerified', 'updatedAt'])
        );

      // Patients may self-create their own document during signup.
      // The document must be for themselves, role must be 'patient',
      // and isVerified must start as false (cannot self-grant verification).
      allow create: if isAdmin()
        || (
          isSignedIn()
          && request.auth.uid == uid
          && request.resource.data.role == 'patient'
          && request.resource.data.active == true
          && request.resource.data.isVerified == false
        );

      allow delete: if isAdmin();
    }

    // ---------- services ----------

    match /services/{serviceId} {
      // ⚠️ ASSUMPTION: the patient app also needs to read services (to let
      // patients pick what they're booking for) — confirm this is still true
      // if/when `reason` is deprecated in favor of `serviceId`. For now, allow
      // any signed-in user (staff or patient) to read.
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ---------- clinicSettings ----------

    match /clinicSettings/{docId} {
      // ⚠️ ASSUMPTION: same as services — patient app likely reads this to
      // compute available slots on its side. Confirm.
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ---------- appointments (shared schema — patient-app owned fields) ----------

    match /appointments/{appointmentId} {

      allow read: if isStaffOrAdmin() || isOwningPatient(resource.data);

      // ⚠️ ASSUMPTION — HIGHEST RISK SECTION:
      // We don't yet know whether the patient app creates appointments via a
      // direct client SDK write, or via its own Cloud Function (which would
      // use the Admin SDK and bypass these rules entirely). The two scenarios
      // require very different rules:
      //
      //   (a) If patient app writes via a Cloud Function (Admin SDK) →
      //       client-side `create` should be locked down entirely except for
      //       this app's own `createWalkInAppointment` — but that ALSO uses a
      //       Cloud Function, so in this scenario NO direct client create is
      //       ever needed and the rule below should be `allow create: if false;`
      //
      //   (b) If patient app creates directly from its client SDK → the rule
      //       below (uncommented) allows a signed-in user to create an
      //       appointment for themselves, but this app should still route
      //       walk-ins through createWalkInAppointment (Admin SDK, bypasses
      //       this rule) rather than a client write.
      //
      // ✅ RESOLVED (decisions-log.md #7, 2026-07-16):
      // The patient app creates appointments directly via the client SDK (scenario b).
      // Staff walk-ins go through createWalkInAppointment (Admin SDK, bypasses this rule).
      // Rule: any signed-in user may create a pending appointment for themselves.
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending'
        && (
          !('bookingSource' in request.resource.data)
          || request.resource.data.bookingSource in ['patient_app', 'patient_web']
        );

      allow update: if isStaffOrAdmin()
          && isValidStatusTransition(resource.data.status, request.resource.data.status)
          // staff/admin may update status, paid, notes, bookingSource-adjacent
          // fields — but must NOT alter patient-app-owned identity fields on
          // a patient-app-originated record
          && onlyStaffManagedFieldsChanged()
        || (
          isOwningPatient(resource.data)
          && resource.data.status in ['pending', 'confirmed']
          && request.resource.data.status == 'cancelled'
          && onlyPatientCancellationFieldsChanged()
        )
        || (
          isOwningPatient(resource.data)
          && resource.data.status in ['pending', 'confirmed']
          && request.resource.data.status == 'pending'
          && onlyPatientRescheduleFieldsChanged()
        );

      allow delete: if false; // soft-delete via status only, never hard delete

      function isValidStatusTransition(oldStatus, newStatus) {
        return (oldStatus == 'pending' && newStatus in ['confirmed', 'cancelled'])
          || (oldStatus == 'confirmed' && newStatus in ['cancelled', 'completed', 'no-show'])
          || (oldStatus == newStatus); // allow no-op status field alongside other field edits
      }

      function onlyStatusFieldChanged() {
        return request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'updatedAt']);
      }

      function onlyPatientCancellationFieldsChanged() {
        return request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'cancellationReason', 'updatedAt']);
      }

      function onlyPatientRescheduleFieldsChanged() {
        return request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['date', 'startTime', 'endTime', 'appointmentDateTime', 'status', 'updatedAt']);
      }

      function onlyStaffManagedFieldsChanged() {
        return request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'paid', 'notes', 'reminderSent', 'updatedAt']);
      }
    }

    // ---------- sso_tokens (single-use SSO handoff tokens) ----------

    match /sso_tokens/{tokenId} {
      // SSO tokens are generated and consumed exclusively via Cloud Functions (Admin SDK).
      // Direct client reads/writes are blocked for security.
      allow read, write: if false;
    }

    // ---------- activity_logs (system audit logs) ----------

    match /activity_logs/{logId} {
      // Readable by staff/admin; writeable by signed-in users creating audit logs;
      // updates and deletes are permanently forbidden (100% immutable).
      allow read: if isStaffOrAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }
  }
}
