# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# ---------- Node / npm (functions/, scripts/) ----------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---------- Cloud Functions build output ----------
functions/lib/
functions/*.tsbuildinfo

# ---------- Firebase ----------
.firebase/
firebase-debug.log
firebase-debug.*.log
ui-debug.log
firestore-debug.log
pubsub-debug.log
database-debug.log
*-debug.log

# Local emulator persisted data (from --export-on-exit) — never commit,
# it's local test data and can get large
emulator-data/

# ---------- Secrets — NEVER commit these ----------
# Firebase Admin SDK service account keys
*-firebase-adminsdk-*.json
serviceAccountKey.json
service-account*.json

# Environment variable files (Cloudinary keys, API secrets, etc.)
.env
.env.local
.env.*.local

# ---------- Notes on files intentionally NOT ignored ----------
# firebase.json, firestore.rules, firestore.indexes.json — required config, must be committed
# lib/firebase_options.dart — contains public client-side Firebase config (safe to commit,
#   this is standard for Flutter web apps; it is not a secret key)